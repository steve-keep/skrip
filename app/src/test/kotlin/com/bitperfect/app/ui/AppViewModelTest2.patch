    @Test
    fun testOnClearedDisconnectsRepository() {
        val application = ApplicationProvider.getApplicationContext<Application>()
        val mockRepo = mock(PlayerRepository::class.java)
        org.mockito.Mockito.`when`(mockRepo.isPlaying).thenReturn(MutableStateFlow(false))
        org.mockito.Mockito.`when`(mockRepo.currentMediaId).thenReturn(MutableStateFlow(null))
        org.mockito.Mockito.`when`(mockRepo.positionMs).thenReturn(MutableStateFlow(0L))

        val vm = AppViewModel(application, mockRepo)
        val onClearedMethod = AppViewModel::class.java.getDeclaredMethod("onCleared")
        onClearedMethod.isAccessible = true
        onClearedMethod.invoke(vm)

        verify(mockRepo).disconnect()
    }

